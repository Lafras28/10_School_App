# Copy this file to .env and replace the URL with your live Render backend.
EXPO_PUBLIC_API_URL=https://your-school-safety-api.onrender.com

# Migration credentials (Firebase Admin SDK) - use one option only.
# Option 1: absolute or relative path to service account json.
FIREBASE_SERVICE_ACCOUNT_PATH=

# Option 2: full json string for service account (single line).
FIREBASE_SERVICE_ACCOUNT_JSON=
